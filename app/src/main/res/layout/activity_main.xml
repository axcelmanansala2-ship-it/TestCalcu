<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/text_secondary"
            android:textSize="22sp"
            android:text=""
            android:maxLines="1"
            android:ellipsize="start" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/text_primary"
            android:textSize="64sp"
            android:text="0"
            android:maxLines="1"
            android:ellipsize="start" />
    </LinearLayout>

    <!-- Button rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Row 1: AC, +/-, %, ⌫ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnClear"
                style="@style/CalcBtn.Function"
                android:text="AC" />

            <Button
                android:id="@+id/btnSign"
                style="@style/CalcBtn.Function"
                android:text="+/-" />

            <Button
                android:id="@+id/btnPercent"
                style="@style/CalcBtn.Function"
                android:text="%" />

            <Button
                android:id="@+id/btnBackspace"
                style="@style/CalcBtn.Function"
                android:text="⌫" />
        </LinearLayout>

        <!-- Row 2: 7, 8, 9, ÷ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn7" style="@style/CalcBtn.Number" android:text="7" />
            <Button android:id="@+id/btn8" style="@style/CalcBtn.Number" android:text="8" />
            <Button android:id="@+id/btn9" style="@style/CalcBtn.Number" android:text="9" />
            <Button android:id="@+id/btnDivide" style="@style/CalcBtn.Operator" android:text="÷" />
        </LinearLayout>

        <!-- Row 3: 4, 5, 6, × -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn4" style="@style/CalcBtn.Number" android:text="4" />
            <Button android:id="@+id/btn5" style="@style/CalcBtn.Number" android:text="5" />
            <Button android:id="@+id/btn6" style="@style/CalcBtn.Number" android:text="6" />
            <Button android:id="@+id/btnMultiply" style="@style/CalcBtn.Operator" android:text="×" />
        </LinearLayout>

        <!-- Row 4: 1, 2, 3, − -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn1" style="@style/CalcBtn.Number" android:text="1" />
            <Button android:id="@+id/btn2" style="@style/CalcBtn.Number" android:text="2" />
            <Button android:id="@+id/btn3" style="@style/CalcBtn.Number" android:text="3" />
            <Button android:id="@+id/btnMinus" style="@style/CalcBtn.Operator" android:text="−" />
        </LinearLayout>

        <!-- Row 5: 0 (wide), ., = , + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn0"
                style="@style/CalcBtn.Number"
                android:layout_weight="2"
                android:text="0"
                android:gravity="center" />

            <Button android:id="@+id/btnDot" style="@style/CalcBtn.Number" android:text="." />
            <Button android:id="@+id/btnPlus" style="@style/CalcBtn.Operator" android:text="+" />
            <Button android:id="@+id/btnEquals" style="@style/CalcBtn.Equals" android:text="=" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
